<Window x:Class="AdvancedTextEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Текстовий редактор" Height="450" Width="800">
    
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Open" Executed="Open_Executed" />
        <CommandBinding Command="ApplicationCommands.Save" Executed="Save_Executed" />
    </Window.CommandBindings>

    <DockPanel>
 
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Command="ApplicationCommands.Open" ToolTip="Відкрити">
                    <Image Source="https://cdn-icons-png.flaticon.com/16/622/622669.png" Width="16"/>
                </Button>
                <Button Command="ApplicationCommands.Save" ToolTip="Зберегти">
                    <Image Source="https://cdn-icons-png.flaticon.com/16/2874/2874040.png" Width="16"/>
                </Button>
                <Separator />
                

                <ToggleButton Command="EditingCommands.ToggleBold" Name="btnBold" ToolTip="Жирний">B</ToggleButton>
                <ToggleButton Command="EditingCommands.ToggleItalic" Name="btnItalic" ToolTip="Курсив">I</ToggleButton>
                <ToggleButton Command="EditingCommands.ToggleUnderline" Name="btnUnderline" ToolTip="Підкреслений">U</ToggleButton>
                
                <Separator />
                

                <Button Click="btnAlignLeft_Click" Content="Left"/>
                <Button Click="btnAlignCenter_Click" Content="Center"/>
                <Button Click="btnAlignRight_Click" Content="Right"/>
                
                <Separator />
                
                <ComboBox Name="cmbFontFamily" Width="150" SelectionChanged="cmbFontFamily_SelectionChanged" />
                <ComboBox Name="cmbFontSize" Width="50" IsEditable="True" TextBoxBase.TextChanged="cmbFontSize_TextChanged" />
                
                <Separator />
                
                <Button Click="btnAddImage_Click" Content=" Image"/>
                <Button Click="btnNewWindow_Click" Content=" New Window"/>
            </ToolBar>
        </ToolBarTray>

 
        <RichTextBox Name="rtbEditor" SelectionChanged="rtbEditor_SelectionChanged" SpellCheck.IsEnabled="True" />
    </DockPanel>
</Window>
